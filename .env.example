# Production: set ONLY this (plus an instance role that can read the secret) —
# src/config/secrets.js fetches the JSON secret and injects every key below
# into the environment at startup. Leave unset for local dev (.env is used).
SECRETS_ARN=

NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Extra browser origins allowed via CORS, comma-separated. localhost:3000,
# localhost:3001, and the Netlify dashboard origin are always allowed; add
# production custom domains here (e.g. https://app.pivot-tech.io).
CORS_ORIGINS=
DATABASE_URL=postgresql://pivottech:pivottech@localhost:5432/pivottech
REDIS_URL=redis://localhost:6379
JWT_SECRET=
JWT_PUBLIC_KEY=
ADMIN_JWT_SECRET=
ADMIN_IP_ALLOWLIST=
# Telnyx — outbound voice/SMS/number provisioning vendor (migrated from SignalWire).
TELNYX_API_KEY=
TELNYX_SIP_CONNECTION_ID=
TELNYX_MESSAGING_PROFILE_ID=
# Outbound voice profile attached to each subscriber DID (authorizes it for
# outbound SIP; without it, outbound calls present the wrong caller ID).
TELNYX_OUTBOUND_VOICE_PROFILE_ID=2999700951977165829
# Ed25519 webhook signing key (base64) from Mission Control / GET /v2/public_key.
# When set, inbound Telnyx webhooks (messaging, voice) are signature-verified;
# leave empty to skip verification (dev). Falls back to GET /v2/public_key if unset.
TELNYX_WEBHOOK_PUBLIC_KEY=
# Shared HMAC-SHA256 secret for the /v1/webhooks/port and /v1/webhooks/telnyx
# routes (the x-telnyx-signature header). Historical env var name.
SIGNALWIRE_WEBHOOK_SECRET=

# Telgoo5 (vCare) billing/BSS integration. baseUrl defaults to the vCare API;
# the rest are the vendor-issued credentials (empty disables live calls).
TELGOO5_BASE_URL=https://www.vcareapi.com:8080
TELGOO5_VENDOR_ID=
TELGOO5_USERNAME=
TELGOO5_PASSWORD=
TELGOO5_PIN=
TELGOO5_AGENT_ID=
TELGOO5_CARRIER=

# Broadband partner API keys — validated against the partner_key sent on
# /v1/partner requests. Empty by default so a missing secret never authorizes a
# partner.
FOX_PARTNER_KEY=
CONFLUENCE_PARTNER_KEY=
# BICS SIMforThings — cellular data / eSIM vendor.
# Credentials are required in production:
BICS_USERNAME=
BICS_PASSWORD=
# Optional; defaults to https://sft.bics.com/api:
BICS_BASE_URL=https://sft.bics.com/api
# Enterprise child account ID for support access (reseller auth)
BICS_TARGET_ACCOUNT_ID=
# PENDING from BICS support — leave blank until provided. createEndpoint falls
# back to these values for plan / APN group / roaming profile.
BICS_PLAN_ID=
BICS_APN_GROUP_ID=
BICS_ROAMING_PROFILE_ID=
# BICS data-usage counter id used when setting the plan threshold on an endpoint.
BICS_DATA_COUNTER_ID=
# How often the background scheduler polls BICS for per-subscriber usage.
USAGE_POLL_INTERVAL_HOURS=4
ACROBITS_CLOUD_ID=54873
ENCRYPTION_KEY=
AWS_REGION=us-east-1
SQS_DID_ASSIGNMENT_QUEUE_URL=
SQS_NOTIFICATION_QUEUE_URL=
# S3 bucket for permanent voicemail recording storage (Telnyx recording URLs
# expire ~10 min). Defaults to mobilitynet-recordings; the bucket must exist and
# the instance role needs s3:PutObject + s3:GetObject on it.
S3_RECORDINGS_BUCKET=mobilitynet-recordings
# Transactional email (Amazon SES). EMAIL_ENABLED defaults to false — when off,
# emails are logged instead of sent (no SES calls, no credentials needed).
EMAIL_FROM=noreply@mymobilitynet.io
EMAIL_ENABLED=false
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=io.pivot-tech.dialer
APNS_PRIVATE_KEY=
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
PROVISIONING_BASE_URL=https://api.pivot-tech.io
PROVISIONING_TOKEN_TTL_HOURS=72
# Dedicated voicemail-menu system DID (E.164). Inbound calls to this number are
# routed to the voicemail IVR instead of a subscriber. Optional.
VOICEMAIL_SYSTEM_DID=
# AWS Transcribe for voicemail transcription. Off by default; set true in prod
# once the App Runner role has transcribe:StartTranscriptionJob +
# transcribe:GetTranscriptionJob (and s3:GetObject on the recordings bucket).
TRANSCRIBE_ENABLED=false
TRANSCRIBE_POLL_INTERVAL_MS=5000
TRANSCRIBE_MAX_POLL_ATTEMPTS=12
