{
  "root": true,
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "extends": "airbnb-base",
  "rules": {
    "no-console": "warn",
    "import/prefer-default-export": "off",
    "camelcase": ["error", { "properties": "never" }]
  }
}
